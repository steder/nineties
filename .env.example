# Nineties — environment variables.
# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Postgres ---
POSTGRES_DB=nineties
POSTGRES_USER=nineties
POSTGRES_PASSWORD=change-me-locally

# --- Django ---
DJANGO_SECRET_KEY=generate-with-django-admin-startproject-or-secrets.token_urlsafe(50)
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,librarian

# --- AudioBookShelf ---
# Generate by logging into AudioBookShelf and creating an API token under Users → root → API Token.
AUDIOBOOKSHELF_TOKEN=

# --- Alexa skill (later, when the skill is set up) ---
ALEXA_SKILL_ID=

# --- Timezone ---
TZ=America/Chicago

# --- OpenRouter (optional, for routing sub-agent work to cheaper models) ---
# OPENROUTER_API_KEY=
